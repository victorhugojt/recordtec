# Database Configuration
DB_NAME=your-database-name
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password

# Connection Type: direct or proxy
# - direct: For local development using public IP with SSL
# - proxy: For GCP VM using Cloud SQL Proxy (recommended for production)
DB_CONNECTION_TYPE=direct

# DB_HOST Configuration:
# For LOCAL testing (direct connection):
DB_HOST=<YOUR_PUBLIC_IP>
# For GCP VM (with Cloud SQL Proxy):
# DB_HOST=cloudsql

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
CLOUDSQL_CONNECTION_NAME=your-project-id:us-central1:your-instance-name

# Application Configuration
APP_ENV=development
LOG_LEVEL=info
